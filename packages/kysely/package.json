{
  "name": "@goodie-ts/kysely",
  "version": "1.0.0",
  "description": "Kysely integration for goodie-ts — @Transactional decorator, TransactionManager, KyselyDatabase",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/GOOD-Code-ApS/goodie.git",
    "directory": "packages/kysely"
  },
  "publishConfig": {
    "access": "public"
  },
  "goodie": {
    "components": "dist/components.json",
    "plugin": "./dist/kysely-transformer-plugin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && goodie generate --mode library",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@goodie-ts/core": ">=2.0.0",
    "kysely": ">=0.27.0",
    "pg": ">=8.0.0",
    "mysql2": ">=3.0.0",
    "better-sqlite3": ">=9.0.0",
    "kysely-neon": ">=0.3.0",
    "kysely-planetscale": ">=1.0.0",
    "@libsql/kysely-libsql": ">=0.4.0",
    "kysely-d1": ">=0.4.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "kysely-neon": {
      "optional": true
    },
    "kysely-planetscale": {
      "optional": true
    },
    "@libsql/kysely-libsql": {
      "optional": true
    },
    "kysely-d1": {
      "optional": true
    }
  },
  "devDependencies": {
    "@goodie-ts/core": "workspace:*",
    "@goodie-ts/cli": "workspace:*",
    "@goodie-ts/transformer": "workspace:*",
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.0.0",
    "better-sqlite3": "^9.0.0",
    "kysely": "^0.27.0",
    "mysql2": "^3.0.0",
    "pg": "^8.0.0",
    "ts-morph": "^24.0.0"
  },
  "files": [
    "dist"
  ]
}
