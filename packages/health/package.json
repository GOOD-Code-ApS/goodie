{
  "name": "@goodie-ts/health",
  "version": "0.5.1",
  "description": "Health check indicators and aggregation for goodie-ts",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/GOOD-Code-ApS/goodie.git",
    "directory": "packages/health"
  },
  "publishConfig": {
    "access": "public"
  },
  "goodie": {
    "plugin": "dist/health-transformer-plugin.js",
    "beans": "dist/beans.json"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsx scripts/generate-beans.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@goodie-ts/decorators": "workspace:^"
  },
  "devDependencies": {
    "@goodie-ts/transformer": "workspace:*",
    "@types/node": "^22.0.0",
    "ts-morph": "^24.0.0",
    "tsx": "^4.21.0"
  },
  "files": [
    "dist"
  ]
}
