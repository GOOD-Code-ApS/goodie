{
  "name": "@goodie-ts/openapi",
  "version": "0.1.0",
  "description": "OpenAPI/Swagger generation from compile-time route metadata for goodie-ts",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/GOOD-Code-ApS/goodie.git",
    "directory": "packages/openapi"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "goodie": {
    "plugin": "dist/plugin.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@goodie-ts/transformer": "workspace:*",
    "@types/node": "^22.0.0",
    "ts-morph": "^24.0.0"
  },
  "files": [
    "dist"
  ]
}
