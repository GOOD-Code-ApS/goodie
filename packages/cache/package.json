{
  "name": "@goodie-ts/cache",
  "version": "0.6.0",
  "description": "Compile-time caching decorators and interceptor for goodie-ts",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/GOOD-Code-ApS/goodie.git",
    "directory": "packages/cache"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
