      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@goodie-ts/aop": "workspace:*"
  },
  "devDependencies": {
    "@goodie-ts/transformer": "workspace:*",
    "@types/node": "^22.0.0",
    "ts-morph": "^24.0.0"
  }
}
