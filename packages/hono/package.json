{
  "name": "@goodie-ts/hono",
  "version": "2.1.0",
  "description": "Hono HTTP controller integration for goodie-ts",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/GOOD-Code-ApS/goodie.git",
    "directory": "packages/hono"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "goodie": {
    "components": "dist/components.json",
    "plugin": "dist/hono-plugin.js"
  },
  "scripts": {
    "build": "tsc && goodie generate --mode library",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@goodie-ts/core": "workspace:*",
    "@goodie-ts/http": "workspace:*",
    "@goodie-ts/cli": "workspace:*",
    "@goodie-ts/transformer": "workspace:*",
    "@types/node": "^22.0.0",
    "ts-morph": "^24.0.0"
  },
  "peerDependencies": {
    "@goodie-ts/core": ">=2.0.0",
    "@goodie-ts/http": ">=1.0.0",
    "@hono/node-server": "^1.0.0",
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@hono/node-server": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ]
}
