{
  "name": "@goodie-ts/hono",
  "version": "0.6.1",
  "description": "Hono HTTP controller integration for goodie-ts",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/GOOD-Code-ApS/goodie.git",
    "directory": "packages/hono"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "goodie": {
    "beans": "dist/beans.json",
    "plugin": "dist/plugin.js"
  },
  "scripts": {
    "build": "tsc && goodie generate --mode library",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@goodie-ts/cli": "workspace:*",
    "@goodie-ts/transformer": "workspace:*",
    "@types/node": "^22.0.0",
    "ts-morph": "^24.0.0"
  },
  "dependencies": {
    "@goodie-ts/core": "workspace:^"
  },
  "peerDependencies": {
    "@hono/node-server": ">=1.0.0",
    "@hono/zod-validator": ">=0.4.0",
    "hono": ">=4.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@hono/node-server": {
      "optional": true
    },
    "@hono/zod-validator": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ]
}
