{
  "name": "@goodie-ts/hono",
  "version": "0.3.0",
  "description": "Hono HTTP controller integration for goodie-ts",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/GOOD-Code-ApS/goodie.git",
    "directory": "packages/hono"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@goodie-ts/core": "workspace:*"
  },
  "devDependencies": {
    "@goodie-ts/transformer": "workspace:*",
    "@types/node": "^22.0.0",
    "ts-morph": "^24.0.0"
  },
  "peerDependencies": {
    "@goodie-ts/transformer": "workspace:*",
    "@hono/node-server": ">=1.0.0",
    "hono": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@goodie-ts/transformer": {
      "optional": true
    },
    "@hono/node-server": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ]
}
